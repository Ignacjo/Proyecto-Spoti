---
const titulo = Astro.props.titulo
const artista = Astro.props.artista
const tiempo = Astro.props.tiempo
const imagen = Astro.props.imagen
---

<div class="flex items-center justify-between hover:bg-zinc-800/50 p-2 rounded-lg transition-colors w-full group">
    
    <div class="flex items-center gap-4">
        <img src={imagen} class="w-[50px] h-[50px] object-cover rounded-md shadow" alt={titulo} />

        <div class="flex flex-col">
            <p class="text-[14px] font-bold text-white uppercase tracking-wider">
                {titulo}
            </p>
            <p class="text-[11px] text-zinc-400">
                {artista}
            </p>
        </div>
    </div>

    <p class="text-[11px] text-zinc-500 font-medium mr-2">
        {tiempo}
    </p>

</div>