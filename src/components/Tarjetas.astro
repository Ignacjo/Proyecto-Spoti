---
const { song } = Astro.props;
---

<div
    class="flex items-center justify-between hover:bg-zinc-800/50 p-2 rounded-lg transition-colors w-full group"
>
    <div class="flex items-center gap-4">
        <img
            src={song.album.image.url}
            alt={song.title}
            class="w-[50px] h-[50px] object-cover rounded-md shadow"
        />

        <div class="flex flex-col">
            <p
                class="text-[14px] font-bold text-white uppercase tracking-wider"
            >
                {song.title}
            </p>
            <p class="text-[11px] text-zinc-400">
                {song.author.name}
            </p>
        </div>
    </div>

    <p class="text-[11px] text-zinc-500 font-medium mr-2">3:00</p>
</div>
