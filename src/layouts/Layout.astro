---
import "../styles/global.css";
import { Icon } from "astro-icon/components";
---

<!doctype html>
<html lang="en">
	<body>
		<header class="flex justify-between bg-[#090909] p-4 px-8 sticky top-0">
			<div class="flex justify-start">
				<a
					href="/"
					class="text-green-500 font-bold text-2xl tracking-tight"
					>Spot</a
				>
			</div>

			<div
				class="flex items-center bg-[#1a1a1a] rounded-full px-4 py-2 w-full max-w-md border border-zinc-700"
			>
				<input
					type="text"
					placeholder="Search for songs, artists, or albums"
					class="bg-transparent outline-none text-[12px] text-zinc-300 w-full"
				/>
			</div>
			<div>
		<Icon name="usa" size="30"/>
			</div>
		</header>
		<slot />
	</body>
</html>
<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
