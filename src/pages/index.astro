---

<Layout>
    <section class="bg-black min-h-screen p-10">
    
    <div class="flex justify-start mb-5">
      <p class="text-white text-4xl font-bold">Popular Songs</p>
    </div>

    <div class="flex flex-col gap-8 justify-start">
      {listadecanciones.map((cancion) => (
        <Tarjetas 
          titulo={cancion.titulo}
          artista={cancion.artista}
          tiempo={cancion.tiempo}
          imagen={cancion.imagen}
        />
